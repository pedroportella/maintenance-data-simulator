{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maintenance-data-simulator.local/schemas/scenario-pack.schema.json",
  "title": "Maintenance planning scenario pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenarioId",
    "name",
    "schemaVersion",
    "seed",
    "referenceTimeUtc",
    "sourceSystem",
    "apiImport",
    "planningHorizon",
    "events",
    "expectedOutcomes"
  ],
  "properties": {
    "scenarioId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "seed": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "referenceTimeUtc": {
      "$ref": "common.schema.json#/$defs/isoDateTime"
    },
    "sourceSystem": {
      "$ref": "common.schema.json#/$defs/sourceSystem"
    },
    "apiImport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "importKind", "batchIdempotencyKey"],
      "properties": {
        "endpoint": {
          "type": "string",
          "enum": [
            "/api/v1/imports/maintenance-events",
            "/api/v1/imports/source-work-orders"
          ]
        },
        "importKind": {
          "type": "string",
          "enum": ["maintenance-events", "source-work-orders"]
        },
        "batchIdempotencyKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      }
    },
    "planningHorizon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startUtc", "endUtc"],
      "properties": {
        "startUtc": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        },
        "endUtc": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenarioEvent"
      }
    },
    "expectedOutcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readyWorkOrderSourceIds",
        "blockedWorkOrderSourceIds",
        "deferredWorkOrderSourceIds",
        "rejectedEventIds",
        "duplicateEventIds",
        "staleEventIds",
        "counts"
      ],
      "properties": {
        "readyWorkOrderSourceIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/sourceIdentifier"
          }
        },
        "blockedWorkOrderSourceIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/sourceIdentifier"
          }
        },
        "deferredWorkOrderSourceIds": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/sourceIdentifier"
          }
        },
        "rejectedEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "duplicateEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "staleEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "readyWorkOrders",
            "blockedWorkOrders",
            "rejectedEvents",
            "deferredWorkOrders"
          ],
          "properties": {
            "readyWorkOrders": {
              "type": "integer",
              "minimum": 0
            },
            "blockedWorkOrders": {
              "type": "integer",
              "minimum": 0
            },
            "rejectedEvents": {
              "type": "integer",
              "minimum": 0
            },
            "deferredWorkOrders": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "scenarioEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventId",
        "eventType",
        "schemaVersion",
        "sourceSystem",
        "sourceRecordId",
        "correlationId",
        "occurredAt",
        "publishedAt",
        "idempotencyKey",
        "payload",
        "expectation"
      ],
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "eventType": {
          "type": "string",
          "enum": [
            "WorkOrderCreated",
            "WorkOrderUpdated",
            "WorkOrderStatusChanged",
            "MajorEventWindowPublished",
            "PartsAvailabilityChanged",
            "CrewCapacityChanged"
          ]
        },
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        },
        "sourceSystem": {
          "$ref": "common.schema.json#/$defs/sourceSystem"
        },
        "sourceRecordId": {
          "$ref": "common.schema.json#/$defs/sourceIdentifier"
        },
        "correlationId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "occurredAt": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        },
        "publishedAt": {
          "$ref": "common.schema.json#/$defs/isoDateTime"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "payload": {
          "type": "object"
        },
        "expectation": {
          "$ref": "#/$defs/eventExpectation"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "eventType": {
                "enum": [
                  "WorkOrderCreated",
                  "WorkOrderUpdated",
                  "WorkOrderStatusChanged"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "payload": {
                "$ref": "payloads/work-order-event-payload.schema.json"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "eventType": {
                "const": "MajorEventWindowPublished"
              }
            }
          },
          "then": {
            "properties": {
              "payload": {
                "$ref": "payloads/major-event-window-payload.schema.json"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "eventType": {
                "const": "PartsAvailabilityChanged"
              }
            }
          },
          "then": {
            "properties": {
              "payload": {
                "$ref": "payloads/parts-availability-payload.schema.json"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "eventType": {
                "const": "CrewCapacityChanged"
              }
            }
          },
          "then": {
            "properties": {
              "payload": {
                "$ref": "payloads/crew-capacity-payload.schema.json"
              }
            }
          }
        }
      ]
    },
    "eventExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["importDisposition"],
      "properties": {
        "importDisposition": {
          "type": "string",
          "enum": [
            "accepted",
            "accepted-blocked",
            "rejected",
            "ignored-duplicate",
            "ignored-stale"
          ]
        },
        "readiness": {
          "type": "string",
          "enum": ["Ready", "NeedsReview", "Blocked"]
        },
        "validationIssues": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/validationIssue"
          },
          "default": []
        },
        "reason": {
          "type": ["string", "null"],
          "maxLength": 500
        }
      }
    }
  }
}
