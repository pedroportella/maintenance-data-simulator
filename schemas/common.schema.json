{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maintenance-data-simulator.local/schemas/common.schema.json",
  "title": "Maintenance planning simulator common contract values",
  "$defs": {
    "isoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "sourceIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "sourceSystem": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "validationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "sourceField": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 120
        },
        "detail": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "sourceDataReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["Ready", "NeedsReview", "Blocked"]
        },
        "issueCode": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 80
        },
        "issueDetail": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 500
        },
        "validationIssues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validationIssue"
          },
          "default": []
        }
      }
    }
  }
}
