{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maintenance-data-simulator.local/schemas/payloads/major-event-window-payload.schema.json",
  "title": "Major event window payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceSystem",
    "sourceId",
    "eventType",
    "title",
    "severity",
    "startsAtUtc",
    "sourceUpdatedAtUtc",
    "sourceDataReadiness"
  ],
  "properties": {
    "sourceSystem": {
      "$ref": "../common.schema.json#/$defs/sourceSystem"
    },
    "sourceId": {
      "$ref": "../common.schema.json#/$defs/sourceIdentifier"
    },
    "eventType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "severity": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "assetSourceId": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 120
    },
    "functionalLocationSourceId": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 120
    },
    "startsAtUtc": {
      "$ref": "../common.schema.json#/$defs/isoDateTime"
    },
    "endsAtUtc": {
      "anyOf": [
        { "$ref": "../common.schema.json#/$defs/isoDateTime" },
        { "type": "null" }
      ]
    },
    "sourceUpdatedAtUtc": {
      "$ref": "../common.schema.json#/$defs/isoDateTime"
    },
    "sourceDataReadiness": {
      "$ref": "../common.schema.json#/$defs/sourceDataReadiness"
    },
    "validationIssues": {
      "type": "array",
      "items": {
        "$ref": "../common.schema.json#/$defs/validationIssue"
      },
      "default": []
    }
  }
}
