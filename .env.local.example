# Local developer configuration. Copy to `.env.local` and edit for your machine.
# `.env.local` is intentionally ignored by Git.

# Local API origin for feed and api-smoke commands when --api-url is omitted.
SIMULATOR_API_URL=http://127.0.0.1:5000

# Synthetic local API bearer token for protected review routes.
SIMULATOR_API_TOKEN=local-reviewer-token

# EventBridge publish mode for deployed review smoke.
# Keep credentials in your AWS CLI profile, task role or shell environment.
SIMULATOR_EVENT_BUS_NAME=
SIMULATOR_AWS_REGION=ap-southeast-2
# SIMULATOR_AWS_PROFILE=review
